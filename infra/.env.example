# ============================================================
# CivicTwin — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# --- Local PostgreSQL (Docker) ---
POSTGRES_DB=civictwin
POSTGRES_USER=civictwin
POSTGRES_PASSWORD=civictwin_dev
POSTGRES_PORT=5432

# --- Supabase (production) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Backend ---
DATABASE_URL=postgresql://civictwin:civictwin_dev@localhost:5432/civictwin
API_HOST=0.0.0.0
API_PORT=8000

# --- Google Earth Engine ---
# GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY_FILE=path/to/key.json

# --- MOSDAC ---
# MOSDAC_USERNAME=your-username
# MOSDAC_PASSWORD=your-password

# --- Hugging Face ---
# HF_TOKEN=hf_your_token_here
# HF_SPACE_URL=https://your-space.hf.space

# --- Frontend (set in Vercel dashboard for production) ---
VITE_API_URL=http://localhost:8000
